# Copy this file to .env.local and replace placeholders with real values.
# Never commit .env.local or real credentials.

# Public browser-side endpoint used by the chatbot.
# Use the production n8n URL with /webhook/..., not /webhook-test/... for normal app usage.
NEXT_PUBLIC_N8N_WEBHOOK=https://your-n8n-instance.com/webhook/your-workflow

# Server-side secrets reserved for AI/database integrations.
# The current frontend build does not require these yet, but keep them here
# so future server routes can read them from process.env without hardcoding.
GEMINI_API_KEY=replace-with-your-gemini-api-key
NOTION_API_KEY=replace-with-your-notion-api-key
NOTION_DATABASE_ID=replace-with-your-notion-database-id
